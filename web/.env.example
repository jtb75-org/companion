# Firebase Configuration (from Firebase Console -> Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Auth provider: firebase|authentik (defaults to firebase when unset).
# authentik = self-hosted BFF cookie session; hides Google sign-in + Register
# since Companion is invite-only. Leave unset/firebase until the deploy flip.
VITE_AUTH_PROVIDER=

# API Base URL. Empty for local dev (Vite proxy); full URL when deployed.
# In CI this is injected from the GH Actions var VITE_API_BASE_URL
# (prod: https://api.mydailydignity.com) — MUST be set or the SPA calls its
# own host and every request 404s/HTML-falls-back to "Access Denied".
VITE_API_BASE_URL=
