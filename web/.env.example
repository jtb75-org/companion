# Auth is Authentik (self-hosted BFF cookie session) — the only supported
# provider. Firebase was fully retired from the web portal. No auth env vars
# are required here; the SPA relies on the BFF session cookie + CSRF token.

# API Base URL. Empty for local dev (Vite proxy); full URL when deployed.
# In CI this is injected from the GH Actions var VITE_API_BASE_URL
# (prod: https://api.mydailydignity.com) — MUST be set or the SPA calls its
# own host and every request 404s/HTML-falls-back to "Access Denied".
VITE_API_BASE_URL=
