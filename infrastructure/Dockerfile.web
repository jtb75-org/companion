# Single-stage nginx image. The Vite bundle (web/dist) is built OUTSIDE the
# Dockerfile by CI (see build-and-push.yml "Build web bundle" step) — kaniko +
# multi-stage hits a registry push-auth bug with our zot setup, same convention
# blue and hillco2 use. For local builds, run `cd web && npm run build` first.
# Context is the repo root (so web/dist and infrastructure/nginx.conf resolve).
FROM nginx:alpine

RUN rm /etc/nginx/conf.d/default.conf
COPY web/dist /usr/share/nginx/html
COPY infrastructure/nginx.conf /etc/nginx/conf.d/default.conf

ARG BUILD_COMMIT=unknown
ENV BUILD_COMMIT=${BUILD_COMMIT}

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
